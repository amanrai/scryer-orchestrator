COMMON_VOLUME_ROOT=/workspace/common-volume
SKILLS_PATHS=["/workspace/common-volume/skills","/workspace/common-volume/everything-claude-code/skills"]
WORKFLOWS_PATH=/workspace/common-volume/workflows
HOOKS_PATH=/workspace/common-volume/hooks
HOOK_FIRES_PATH=/workspace/common-volume/hook-fires
DATA_DIR=/workspace/common-volume/new-orchestrator/data
CORS_ORIGINS=["*"]
VALKEY_URL=redis://valkey:6379
VALKEY_CHANNEL_AGENT_TO_UI=agent:to:ui
VALKEY_CHANNEL_NOTIFICATIONS=agent:notifications
PROCESS_TIMEOUT_SECONDS=86400
TMUX_SOCKET_NAME=new-orchestrator
ORCHESTRATOR_URL=http://new-orchestrator:8101
TMUXER_URL=http://host.docker.internal:5678
INTERACTION_SERVICE_URL=http://interaction-service:8200
SECRETS_SERVICE_URL=http://host.docker.internal:8211
